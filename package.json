{
    "name": "svelte5-bun-demo",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "workspaces": [
        "packages/*",
        "examples"
    ],
    "dependencies": {
        "bun-svelte-builder": "workspace:*"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "svelte": "next"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build": "bun run build.ts",
        "check": "bun run typecheck && bun test",
        "dev": "bun --hot server.ts",
        "test": "bun test",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
