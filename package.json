{
    "name": "bun-svelte-builder",
    "version": "0.0.0",
    "description": "Minimal Bun + Svelte 5 production build preset.",
    "bin": {
        "bun-svelte-builder": "./src/cli.ts"
    },
    "module": "./src/index.ts",
    "type": "module",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/6643/bun-svelte-builder.git"
    },
    "exports": {
        ".": "./src/index.ts",
        "./runtime": "./src/runtime.ts",
        "./build": "./src/build.ts",
        "./package.json": "./package.json"
    },
    "files": [
        "src",
        "README.md",
        "package.json"
    ],
    "workspaces": [
        "examples"
    ],
    "devDependencies": {
        "@types/bun": "latest",
        "svelte": "next"
    },
    "peerDependencies": {
        "svelte": "next",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build": "bun run build.ts",
        "check": "bun run typecheck && bun test",
        "dev": "bun --hot server.ts",
        "test": "bun test",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
